# UID/GID of the host user that owns the mounted volumes
# Run `id` on the host to find yours
# PUID=1000
# PGID=1000

# Logging: DEBUG, INFO (default), WARNING, ERROR
# LOG_LEVEL=INFO

DAHUA_HOST=192.168.1.108
DAHUA_PORT=80
DAHUA_USER=admin
DAHUA_PASS=passwdpasswd
# DAHUA_EVENTS=All
DAHUA_IVS_NAMES=CarDetection
# Optional: city name for sunrise/sunset (lat, lon and timezone looked up automatically)
# CITY=Helsinki

# Intrusion detection IVS rule name (as configured on the camera)
DAHUA_INTRUSION_IVS_NAME=Intrusion
# Fallback debounce window (seconds) when no video file is available yet.
# The primary debounce uses the actual video recording end time from DAV files;
# this value is only used while the camera is still recording (file not uploaded).
# INTRUSION_DEBOUNCE_SECS=120
# Path inside container where camera FTP uploads are mounted (read-only)
# INTRUSION_MEDIA_PATH=/media
# Video cache size limit in GB
# VIDEO_CACHE_MAX_GB=20
# Hardware acceleration for video encoding: auto (default) or off.
# "auto" probes for Intel QSV at startup and falls back to software.
# VIDEO_HW_ACCEL=auto
# System / camera timezone (IANA name).  Camera FTP filenames use local time;
# this converts them to UTC for matching with events.  Also sets the
# container's system timezone.
# TZ=Europe/Warsaw

# Host path to camera FTP uploads directory (mounted read-only into the container)
MEDIA_HOST_PATH=/path/to/camera/ftp/uploads

# --- ntfy.sh push notifications (intrusion events) ---
# Notifications are disabled by default; set NTFY_TOPIC to enable.
# NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
# Access token for authenticated topics (optional).
# NTFY_TOKEN=tk_...
# Notification priority: min, low, default, high, urgent (default high).
# NTFY_PRIORITY=high
# Seconds to wait for camera snapshot before sending the initial notification (default 10).
# NTFY_SNAPSHOT_WAIT=10

# --- Ollama video analysis (intrusion events) ---
# Requires a vision-capable model (e.g. qwen3-vl:8b, llava). Text-only models will not work.
# OLLAMA_HOST is set in docker-compose to http://ollama:11434 when using the ollama network.
# OLLAMA_MODEL=qwen3-vl:8b
# Optional: custom prompt for the vision model (default describes security camera video analysis).
# OLLAMA_PROMPT=You are analyzing frames extracted from a security camera video...
# Seconds to wait for the video recording (DAV) to finish uploading (default 300).
# ANALYSIS_VIDEO_WAIT=300
# Max width (px) for frames sent to LLM; larger frames are downscaled (default 512).
# ANALYSIS_FRAME_WIDTH=512
# Motion detection threshold (0-1). Lower = more frames kept (default 0.015).
# ANALYSIS_MOTION_THRESHOLD=0.015
# Interval in seconds between candidate frames for motion detection (default 0.5).
# ANALYSIS_MOTION_SAMPLE_RATE=0.5
# Path to motion mask image (white=monitor, black=ignore). Must match frame
# dimensions at ANALYSIS_FRAME_WIDTH. Default: bundled mask. Set to "none" to disable.
# ANALYSIS_MOTION_MASK=
# Ollama context window size (default 8192).
# OLLAMA_NUM_CTX=8192
# Timeout for Ollama API request in seconds (default 600).
# OLLAMA_TIMEOUT=600
