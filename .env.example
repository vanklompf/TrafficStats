# UID/GID of the host user that owns the mounted volumes
# Run `id` on the host to find yours
# PUID=1000
# PGID=1000

# Logging: DEBUG, INFO (default), WARNING, ERROR
# LOG_LEVEL=INFO

DAHUA_HOST=192.168.1.108
DAHUA_PORT=80
DAHUA_USER=admin
DAHUA_PASS=passwdpasswd
# DAHUA_EVENTS=All
DAHUA_IVS_NAMES=CarDetection
# Optional: city name for sunrise/sunset (lat, lon and timezone looked up automatically)
# CITY=Helsinki

# Intrusion detection IVS rule name (as configured on the camera)
DAHUA_INTRUSION_IVS_NAME=Intrusion
# Fallback debounce window (seconds) when no video file is available yet.
# The primary debounce uses the actual video recording end time from DAV files;
# this value is only used while the camera is still recording (file not uploaded).
# INTRUSION_DEBOUNCE_SECS=120
# Path inside container where camera FTP uploads are mounted (read-only)
# INTRUSION_MEDIA_PATH=/media
# Video cache size limit in GB
# VIDEO_CACHE_MAX_GB=20
# Hardware acceleration for video encoding: auto (default) or off.
# "auto" probes for Intel QSV at startup and falls back to software.
# VIDEO_HW_ACCEL=auto
# System / camera timezone (IANA name).  Camera FTP filenames use local time;
# this converts them to UTC for matching with events.  Also sets the
# container's system timezone.
# TZ=Europe/Warsaw

# Host path to camera FTP uploads directory (mounted read-only into the container)
MEDIA_HOST_PATH=/path/to/camera/ftp/uploads

# --- Ollama snapshot analysis (intrusion events) ---
# Requires a vision-capable model (e.g. moondream, llava). Text-only models (e.g. qwen3.5) will not work.
# OLLAMA_HOST is set in docker-compose to http://ollama:11434 when using the ollama network.
# OLLAMA_MODEL=moondream
# Optional: custom prompt for the vision model (default describes security camera analysis).
# OLLAMA_PROMPT=Describe what you see in this security camera image.
# Seconds to wait for the snapshot file to appear on disk before giving up (default 120).
# ANALYSIS_SNAPSHOT_WAIT=120
# Timeout for Ollama API request in seconds (default 600).
# OLLAMA_TIMEOUT=600
